  journal = {Landscape Ecology},
  issn = {1572-9761},
  doi = {10.1007/s10980-022-01453-5},
  urldate = {2022-06-21},
  abstract = {Many forest ecosystems around the world are facing increasing drought-induced dieback, causing mortality patches across the landscape at multiple scales. This increases the supply of biological legacies and differentially affects forest insect communities.},
  copyright = {All rights reserved},
  langid = {english},
  keywords = {Climate change,Disturbance legacy,Drought,Forest decline,Saproxylic beetles,Scale of effect},
